# ═══════════════════════════════════════════════════════════════
#  TEMPO TERMINAL · Configuration Template
#  Copy to .env and fill in the values that matter to you.
# ═══════════════════════════════════════════════════════════════

# ── Spending guard ─────────────────────────────────────────────
# Local soft cap on daily spend (USD). The Tempo wallet itself
# enforces a separate hard cap via the access-key spending_limit
# (visible in `tempo wallet -t whoami`). Both should be set.
MAX_DAILY_SPEND=3.0

# Operations costing strictly more than this prompt the user before
# charging. $0.05 catches premium-model chat, multi-URL extract, and
# anything else that isn't trivially cheap. Research and music
# always confirm regardless (long-running, easy to misfire).
CONFIRM_THRESHOLD=0.05

# Low-balance alert thresholds (USDC available).
LOW_BALANCE_WARN=5.0
LOW_BALANCE_CRITICAL=1.0

# ── Default LLM ────────────────────────────────────────────────
# Any model from MODEL_CATALOG; users can switch per-session via /model.
LLM_MODEL=openai/gpt-4o-mini

# ── Web UI ─────────────────────────────────────────────────────
PORT=3000
# Set to 0.0.0.0 ONLY if you understand that everyone on your LAN
# can then drive your wallet. Default 127.0.0.1 keeps the bot local.
# BIND_HOST=127.0.0.1

# ── Telegram bot (optional) ────────────────────────────────────
# Get a token from @BotFather, your numeric ID from @userinfobot.
# Without ALLOWED_USERS the bot is OPEN — anyone who finds it
# can drain your wallet. Always whitelist.
TELEGRAM_BOT_TOKEN=
ALLOWED_USERS=

# ── Telegram tunables ──────────────────────────────────────────
# Conversation memory window (last N exchanges). Opt-in via /context on.
CONTEXT_WINDOW=6

# Per-user rate limit: minimum seconds between messages, max per minute.
RATE_LIMIT_SEC=2.0
RATE_LIMIT_MIN=20

# Default TTS voice (rachel|adam|antoni|bella|domi|elli). Each maps to
# a Deepgram Aura model; users can switch via /voice.
TTS_VOICE=rachel
